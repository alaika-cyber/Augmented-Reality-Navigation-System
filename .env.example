# ============================================================
# Environment Configuration
# Copy this to .env and modify as needed
# ============================================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# --- YOLOv8 Detection ---
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.45
YOLO_IOU=0.5
YOLO_DEVICE=cpu
YOLO_INPUT_SIZE=640
FRAME_SKIP=2

# --- Custom Model (optional – for stairs/pothole/wall) ---
# CUSTOM_MODEL_PATH=custom_model.pt

# --- Text-to-Speech ---
TTS_ENGINE=pyttsx3
TTS_RATE=175
TTS_VOLUME=1.0
TTS_COOLDOWN=2.0

# --- GPS ---
GPS_INTERVAL=5.0
EMERGENCY_MSG=Emergency! I need help. My current location:
